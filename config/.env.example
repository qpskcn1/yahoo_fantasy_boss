# Yahoo Fantasy API Credentials
YAHOO_CLIENT_ID=your_client_id_here
YAHOO_CLIENT_SECRET=your_client_secret_here

# Optional: Pre-configured Tokens (if available)
YAHOO_REFRESH_TOKEN=your_refresh_token_here
YAHOO_ACCESS_TOKEN=your_access_token_here

# League Details
# Usually format: league_key = {game_key}.l.{league_id}
# e.g., 422.l.12345 (422 is NBA 2023-24, game_key changes every year)
YAHOO_LEAGUE_KEY=422.l.your_league_id

# Team Details
# Format: {league_key}.t.{team_id}
YAHOO_TEAM_ID=your_team_id
